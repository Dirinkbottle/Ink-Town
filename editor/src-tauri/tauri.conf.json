{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ink Town",
  "version": "0.1.0",
  "identifier": "com.inktown.editor",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "features": ["desktop"]
  },
  "app": {
    "windows": [
      {
        "title": "Ink Town Editor",
        "label": "main",
        "width": 1400,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
